{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["monthly"],
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["mise"],
      "commitMessagePrefix": "mise:",
      "commitMessageAction": "update",
      "groupName": "tools"
    },
    {
      "matchManagers": ["npm"],
      "commitMessagePrefix": "*:",
      "commitMessageAction": "update",
      "groupName": "npm dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": ".github/workflows:",
      "commitMessageAction": "update",
      "groupName": "GitHub Actions"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["monthly"],
    "commitMessagePrefix": "*:",
    "commitMessageAction": "update",
    "groupName": "lockfiles"
  }
}
